{
  "name": "ticket-to-pr",
  "private": true,
  "version": "0.1.0",
  "license": "BUSL-1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Juyeong-Byeon/PatchPilot.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node scripts/build-workspaces-if-source.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "node scripts/verify.mjs",
    "typecheck": "node scripts/typecheck-workspaces.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:commits": "commitlint --from origin/main",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "node scripts/setup.mjs",
    "stack": "node scripts/stack.mjs",
    "doctor": "node scripts/preflight.mjs",
    "doctor:strict": "node scripts/preflight.mjs --strict",
    "status": "node scripts/status.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "dev:watch": "node scripts/dev-watch.mjs",
    "logs": "docker compose logs -f api worker admin",
    "down": "docker compose down",
    "reset:db": "node scripts/reset-db.mjs",
    "update": "node scripts/update.mjs",
    "dev:update": "node scripts/dev-update.mjs",
    "dev:refresh": "node scripts/dev-update.mjs --no-pull",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "dev:api": "npm --workspace @ticket-to-pr/api run dev",
    "dev:worker": "npm --workspace @ticket-to-pr/worker run dev",
    "dev:admin": "npm --workspace @ticket-to-pr/admin run dev",
    "db:migrate": "npm run build --workspace @ticket-to-pr/core && npm --workspace @ticket-to-pr/db run migrate",
    "docker:build-runtime": "node scripts/docker-build-runtime.mjs",
    "docker:frontend": "docker compose up -d --build admin",
    "docker:recreate-worker": "docker compose up -d --force-recreate worker",
    "docker:refresh-runtime": "npm run docker:build-runtime && npm run docker:recreate-worker"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.1.3",
    "@octokit/rest": "^21.0.2",
    "bullmq": "^5.34.3",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  }
}
