# Build context excludes. The api/worker/runner Dockerfiles run `npm ci` and
# rebuild every workspace from source, so dependencies and prior build outputs
# must NOT be shipped in the context: they bloat the upload, can leak stale
# artifacts into the image, and defeat layer caching. Keep this conservative —
# everything the Dockerfiles COPY (package*.json, tsconfig.base.json, scripts/,
# packages/, apps/ sources) must stay out of these patterns.

# Dependencies — regenerated by `npm ci` inside the image
node_modules
**/node_modules

# Compiled output — rebuilt inside the image (and may be stale locally)
dist
**/dist

# Test/coverage output
coverage
**/coverage

# Local secrets & env — must never enter the build context
.env
.env.*
!.env.example

# Job workspaces / runtime volume (mounted at runtime; can be very large)
work

# Version control & local agent/editor tooling
.git
.gitignore
.github
.superpowers
.claude

# OS / editor noise
.DS_Store
*.log
