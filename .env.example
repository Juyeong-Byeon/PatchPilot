NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
HOST_API_PORT=3000
HOST_ADMIN_PORT=5173
# Local admin frontend requests /api on the current frontend origin; Vite proxies
# those requests to ADMIN_API_PROXY_TARGET. Leave VITE_ADMIN_API_BASE_URL blank
# unless the browser must call a separate API origin directly.
ADMIN_API_PROXY_TARGET=
VITE_ADMIN_API_BASE_URL=
# Comma-separated Vite dev-server host allowlist for Tailnet or tunnel sharing.
# Example: dev-machine.tailnet.example.ts.net,.trycloudflare.com
ADMIN_ALLOWED_HOSTS=
ADMIN_TOKEN=change-me-admin-token
DATABASE_URL=postgres://ticket_to_pr:ticket_to_pr@postgres:5432/ticket_to_pr
REDIS_URL=redis://redis:6379
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=secret_xxx
LARK_WEBHOOK_SECRET=webhook_secret_xxx
LARK_BASE_APP_TOKEN=base_app_token_xxx
LARK_BASE_TABLE_ID=table_xxx
LARK_STATUS_FIELD=PatchPilot Status
LARK_JOB_ID_FIELD=PatchPilot Job ID
LARK_PR_URL_FIELD=PR URL
LARK_PR_NUMBER_FIELD=PR Number
LARK_FAILURE_FIELD=PatchPilot Failure
LARK_UPDATED_AT_FIELD=PatchPilot Updated At
GITHUB_TOKEN=github_pat_xxx
GITHUB_WEBHOOK_SECRET=github_webhook_secret_xxx
REPOSITORY_ALLOWLIST=owner/repo
PROTECTED_PATH_DENYLIST=.env,.env.*,infra/**,terraform/**,secrets/**,migrations/prod/**
JOB_WORKSPACE_ROOT=/work/jobs
JOB_TIMEOUT_SECONDS=3600
FAILED_WORKSPACE_RETENTION_DAYS=7
EXECUTOR_MODE=mock
PUBLISHER_MODE=mock
RUNNER_IMAGE=ticket-to-pr-runner:local

GSTACK_COMMAND=node
# Leave GSTACK_ARGS blank for per-ticket pipeline selection. Set it only when you
# intentionally want to force one runner entrypoint for every job.
GSTACK_ARGS=
GSTACK_SINGLE_ARGS=/opt/runner/apps/runner/dist/codex-agent-runner.js
GSTACK_STAGED_ARGS=/opt/runner/apps/runner/dist/gstack-staged-runner.js
GSTACK_INSTALL_COMMAND=npm install -g @openai/codex@0.141.0
CODEX_AUTH_FILE=$HOME/.codex/auth.json
CODEX_CONFIG_FILE=$HOME/.codex/config.toml
CODEX_SKILLS_DIR=$HOME/.codex/skills
GSTACK_SKILL_SOURCE_DIR=$HOME/gstack
